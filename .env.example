# Core
POSTGRES_DB=oil_intelligence
POSTGRES_USER=oil
POSTGRES_PASSWORD=oil
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_BASE_PREFIX=/api
API_VERSION=v1
AUTO_CREATE_TABLES=true
LOG_LEVEL=INFO
LOG_JSON=true
REQUEST_ID_HEADER=X-Request-ID
DEFAULT_PAGE_LIMIT=100
MAX_PAGE_LIMIT=1000

CELERY_MARKET_REFRESH_MINUTES=30
CELERY_EVENTS_REFRESH_MINUTES=15
CELERY_ALERTS_REFRESH_MINUTES=20

# Optional external keys (mock mode enabled when missing)
OPENAI_API_KEY=
EIA_API_KEY=
FRED_API_KEY=
GDELT_API_KEY=
SENTINEL_HUB_API_KEY=
NASA_FIRMS_API_KEY=
COMMERCIAL_SAT_API_KEY=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
